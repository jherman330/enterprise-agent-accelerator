# Azure OpenAI / AI Foundry model endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Model deployment name or identifier
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# API key (local development only - use Managed Identity in production)
AZURE_OPENAI_API_KEY=your-api-key-here

# React Frontend origin allowed by the local CORS policy
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Base URL of the ASP.NET Core API (used by the React frontend)
VITE_API_BASE_URL=http://localhost:8080
